#!/usr/bin/env zsh

set -e
setopt NULL_GLOB
setopt EXTENDED_GLOB
setopt DOTGLOB

source ${0:h}/../../dotfiles.lib.zsh

pacmanpkg_path=$(realpath ${0:h}/../../packages)

typeset -A pacmanpackages

for d in $pacmanpkg_path/<0-9>##_*
do
    if [ ! -d $d ];
    then
        continue
    fi

    if [ ! -e $d/pacman ];
    then
        continue
    fi

    if ! dotfiles_check_machine $d; then
        continue
    fi

    source $d/pacman
done

for pkg install_args in "${(@kv)pacmanpackages}"; do
    if ! pacman -Qe $pkg >/dev/null 2>&1; then
        sudo pacman -S --noconfirm ${pkg} ${(z)install_args}
    fi
done
